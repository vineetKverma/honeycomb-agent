# --- Secrets / environment (NEVER commit) ---
.env
.env.*
!.env.example

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Virtual environments ---
venv/
.venv/
env/
ENV/

# --- OS cruft ---
.DS_Store
Thumbs.db

# --- Honeycomb generated data / artifacts ---
data/cache/
data/eval_results.json
*.log

# --- Editor / tooling ---
.idea/
.vscode/
# Claude Code local settings: auto-recorded permission rules can embed secrets
# (command args), so keep the whole dir out of git.
.claude/
